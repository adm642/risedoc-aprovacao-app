# Copie este arquivo para .env.local e preencha com os valores reais.
# As chaves do Supabase ficam em: Project Settings → API
# Ver guia completo no vault: "Guia de Configuração — Contas e Serviços"

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=          # SECRETA — nunca expor no cliente

# Resend (e-mails)
RESEND_API_KEY=
# Remetente verificado no Resend (precisa do domínio validado lá)
MAIL_FROM=Risedoc Aprovações <aprovacao@risedoc.com.br>

# URL pública do app
NEXT_PUBLIC_APP_URL=https://app.risedoc.com.br
