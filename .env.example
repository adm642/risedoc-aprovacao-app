# Copie este arquivo para .env.local e preencha com os valores reais.
# As chaves do Supabase ficam em: Project Settings → API
# Ver guia completo no vault: "Guia de Configuração — Contas e Serviços"

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=          # SECRETA — nunca expor no cliente

# Resend (e-mails)
RESEND_API_KEY=

# URL pública do app
NEXT_PUBLIC_APP_URL=http://localhost:3000
